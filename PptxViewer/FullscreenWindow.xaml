<Window x:Class="PptxViewer.FullscreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        WindowState="Maximized"
        Background="Black"
        KeyDown="Window_KeyDown"
        Title="Slideshow">

    <Grid>
        <!-- Slide Canvas centered -->
        <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Canvas x:Name="FsCanvas" Width="960" Height="540" Background="White"/>
        </Viewbox>

        <!-- Slide counter overlay -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="16" Background="#80000000" CornerRadius="6" Padding="10,4">
            <TextBlock x:Name="SlideCounter" Foreground="White" FontSize="14"/>
        </Border>

        <!-- ESC hint -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="16" Background="#80000000" CornerRadius="6" Padding="10,4">
            <TextBlock Text="ESC to exit  |  ← → to navigate" Foreground="#AAA" FontSize="12"/>
        </Border>
    </Grid>
</Window>
