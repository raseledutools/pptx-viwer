<Window x:Class="PptxViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PPTX Viewer" Height="720" Width="1200"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Notes -->
            <RowDefinition Height="40"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════ TOOLBAR ══════════════ -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#333" BorderThickness="0,0,0,1">
            <DockPanel Margin="8,0">
                <!-- Open button -->
                <Button DockPanel.Dock="Left" Style="{StaticResource NavButton}"
                        Click="OpenFile_Click" Margin="0,6,8,6" Padding="16,6">
                    📂 Open PPTX
                </Button>

                <!-- Zoom controls -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <Button Style="{StaticResource NavButton}" Click="ZoomOut_Click"
                            Padding="10,6" Margin="2,6" ToolTip="Zoom Out (-)">－</Button>
                    <TextBlock x:Name="ZoomLabel" Text="100%" Foreground="#AAA"
                               VerticalAlignment="Center" Margin="6,0" FontSize="13"/>
                    <Button Style="{StaticResource NavButton}" Click="ZoomIn_Click"
                            Padding="10,6" Margin="2,6" ToolTip="Zoom In (+)">＋</Button>
                    <Button Style="{StaticResource NavButton}" Click="ZoomReset_Click"
                            Padding="10,6" Margin="2,6" ToolTip="Reset Zoom">⌂</Button>
                </StackPanel>

                <!-- Fullscreen -->
                <Button DockPanel.Dock="Right" Style="{StaticResource NavButton}"
                        Click="Fullscreen_Click" Margin="4,6" Padding="10,6"
                        ToolTip="Fullscreen Slideshow (F5)">
                    ⛶ Slideshow
                </Button>

                <!-- Notes toggle -->
                <Button DockPanel.Dock="Right" Style="{StaticResource NavButton}"
                        Click="ToggleNotes_Click" Margin="4,6" Padding="10,6"
                        ToolTip="Toggle Notes Panel">
                    📝 Notes
                </Button>

                <!-- Navigation -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource NavButton}" Click="PrevSlide_Click"
                            x:Name="BtnPrev" Padding="14,6" Margin="4,6" ToolTip="Previous (←)">◀</Button>
                    <Border Background="#2D2D2D" BorderBrush="#444" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" Margin="4,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="SlideNumberBox" Width="36" Background="Transparent"
                                     Foreground="White" BorderThickness="0" TextAlignment="Center"
                                     FontSize="13" VerticalAlignment="Center"
                                     KeyDown="SlideNumberBox_KeyDown" Text="0"/>
                            <TextBlock Text=" / " Foreground="#888" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalSlides" Text="0" Foreground="#AAA"
                                       VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource NavButton}" Click="NextSlide_Click"
                            x:Name="BtnNext" Padding="14,6" Margin="4,6" ToolTip="Next (→)">▶</Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════════════ MAIN CONTENT ══════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" MinWidth="100" MaxWidth="300"/>
                <ColumnDefinition Width="5"/>   <!-- Splitter -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Thumbnail Sidebar -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#333" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="SLIDES" Foreground="#888" FontSize="11"
                               FontWeight="Bold" Margin="12,8"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ListBox x:Name="ThumbnailList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 SelectionChanged="ThumbnailList_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="Margin" Value="4,2"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3E3E5E"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2E2E3E"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Border BorderBrush="#555" BorderThickness="1" CornerRadius="3">
                                            <Image Source="{Binding Thumbnail}" Width="148" Height="83"
                                                   Stretch="Uniform"/>
                                        </Border>
                                        <TextBlock Text="{Binding Index}" Foreground="#888"
                                                   FontSize="10" HorizontalAlignment="Center"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Grid Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#333" Cursor="SizeWE"/>

            <!-- Slide Canvas Area -->
            <Border Grid.Column="2" Background="#121212">
                <ScrollViewer x:Name="SlideScroller"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                          Margin="24">
                        <!-- Drop hint -->
                        <TextBlock x:Name="DropHint"
                                   Text="📂  Open a PPTX file to get started&#x0a;or drag &amp; drop here"
                                   Foreground="#555" FontSize="20" TextAlignment="Center"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Slide render target -->
                        <Border x:Name="SlideContainer"
                                Background="White" CornerRadius="4"
                                Visibility="Collapsed">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.6"
                                                  BlurRadius="20" ShadowDepth="4"/>
                            </Border.Effect>
                            <Canvas x:Name="SlideCanvas" Width="960" Height="540"
                                    ClipToBounds="True"/>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ══════════════ NOTES PANEL ══════════════ -->
        <Border Grid.Row="2" x:Name="NotesPanel" Background="#1A1A2E"
                BorderBrush="#333" BorderThickness="0,1,0,0"
                Height="140" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="SPEAKER NOTES" Foreground="#888" FontSize="11"
                           FontWeight="Bold" Margin="12,6"/>
                <ScrollViewer Grid.Row="1" Margin="12,0,12,8"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="NotesText"
                               TextWrapping="Wrap" Foreground="#CCC"
                               FontSize="13" LineHeight="20"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ══════════════ STATUS BAR ══════════════ -->
        <Border Grid.Row="3" Background="#007ACC" Padding="12,0">
            <DockPanel>
                <TextBlock x:Name="StatusText" Text="Ready — Open a PPTX file"
                           Foreground="White" VerticalAlignment="Center" FontSize="12"/>
                <TextBlock x:Name="FilePath" DockPanel.Dock="Right"
                           Foreground="#BEE" VerticalAlignment="Center"
                           FontSize="11" Opacity="0.8"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
